APP_DEBUG=True            # True para desenvolvimento, False para produção

# Chave secreta usada para assinar tokens (JWT, sessões, cookies, etc.)
SECRET_KEY="sua_secret_key_segura_e_aleatoria_aqui"


# ==========================================
# Configurações de Banco de Dados
# ==========================================
DB_CONNECTION="postgresql"  # Opções: postgresql, mysql, sqlite, etc.
DB_HOST="127.0.0.1"         # Ou o endereço do container Docker (ex: db)
DB_PORT=5432                # 5432 para Postgres, 3306 para MySQL
DB_DATABASE="nome_do_banco_de_dados"
DB_USERNAME="usuario_do_banco"
DB_PASSWORD="senha_do_banco"
